# ============================================
# Neo4j Connection
# ============================================
NEO4J_URI=                      # Neo4j connection URI (e.g., neo4j+s://xxx.databases.neo4j.io)
NEO4J_USERNAME=                 # Neo4j username
NEO4J_PASSWORD=                 # Neo4j password
NEO4J_VECTOR_INDEX_NAME=chunkEmbeddings  # Neo4j vector index name (default: chunkEmbeddings)
NEO4J_FULLTEXT_INDEX_NAME=search_chunks  # Neo4j fulltext index for chunk text search (default: search_chunks)
NEO4J_FULLTEXT_ENTITY_INDEX_NAME=search_entities  # Neo4j fulltext index for entity name search (default: search_entities)

# Embedding Configuration
EMBEDDING_DIMENSIONS=1536       # Embedding dimensions (1536 for text-embedding-3-small)

# ============================================
# Azure Configuration
# ============================================
# Get your project endpoint from the Foundry portal (ai.azure.com) — see Lab 3.

AZURE_AI_PROJECT_ENDPOINT=      # Microsoft Foundry project endpoint (e.g., https://<resource>.services.ai.azure.com/api/projects/<project>)
AZURE_AI_MODEL_NAME=gpt-4o-mini # Chat model deployment name from Lab 3 (gpt-4o-mini or gpt-4o)
AZURE_AI_EMBEDDING_NAME=text-embedding-3-small  # Embedding model deployment name from Lab 3
