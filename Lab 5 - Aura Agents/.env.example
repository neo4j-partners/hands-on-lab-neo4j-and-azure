# Neo4j Aura Agent MCP Server Configuration
# Copy this file to .env and fill in your values

# MCP server endpoint URL (from Aura Console -> Agents -> ... -> Copy MCP server endpoint)
AURA_AGENT_MCP_SERVER=https://mcp.neo4j.io/agent?project_id=YOUR_PROJECT_ID&agent_id=YOUR_AGENT_ID

# API credentials (from Aura Console -> Account Settings -> API Keys)
AURA_CLIENT_ID=YOUR_CLIENT_ID
AURA_CLIENT_SECRET=YOUR_CLIENT_SECRET
